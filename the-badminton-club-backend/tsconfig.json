{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",            // must match moduleResolution
    "moduleResolution": "NodeNext",  // ESM-aware resolution
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"]
}