// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model SessionTemplate {
  id        Int       @id @default(autoincrement())
  title     String
  type      String
  level     String
  dayOfWeek String
  startTime String
  duration  Int
  coach     String?
  location  String?
  latitude  Float?    // New
  longitude Float?    // New
  capacity  Int
  price     Int
  sessions  Session[]
}

model Session {
  id          Int       @id @default(autoincrement())
  templateId  Int?
  title       String
  description String
  date        DateTime
  location    String
  latitude    Float?    // optional for map
  longitude   Float?    // optional for map
  level       String
  capacity    Int
  price       Int
  coach       String?   // NEW: nullable coach
  bookings    Booking[]
  template    SessionTemplate? @relation(fields: [templateId], references: [id])
}

model Booking {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  session   Session  @relation(fields: [sessionId], references: [id])
  sessionId Int
  createdAt DateTime @default(now())
}